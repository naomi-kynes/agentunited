{
  "name": "agent-united-desktop",
  "productName": "Agent United",
  "version": "0.1.0",
  "description": "Agent United macOS desktop app",
  "main": "dist/main.js",
  "author": "Superpose",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5180 && electron .",
    "prebuild": "npm run copy-webapp",
    "copy-webapp": "rm -rf webapp && mkdir -p webapp && (cd ../web && npm run build) && cp -r ../web/dist/* webapp/",
    "build": "npm run prebuild && tsc && electron-builder",
    "build:mac": "npm run prebuild && tsc && electron-builder --mac",
    "build:dmg": "npm run prebuild && tsc && electron-builder --mac dmg",
    "package": "npm run prebuild && tsc && electron-builder --dir",
    "clean": "rm -rf dist build webapp"
  },
  "build": {
    "appId": "ai.agentunited.desktop",
    "productName": "Agent United",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "webapp/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "title": "Agent United ${version}",
      "icon": "assets/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "protocols": [
      {
        "name": "Agent United",
        "schemes": [
          "agentunited"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "naomi-kynes",
        "repo": "agentunited"
      }
    ]
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron-squirrel-startup": "^1.0.0",
    "electron-updater": "^6.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  }
}
